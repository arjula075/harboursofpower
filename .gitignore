# --- Godot 4 ---------------------------------------------------------------
# Editor cache and local import artifacts (regenerated on open)
.godot/

# Godot 3 legacy import folder (harmless if unused)
.import/

# Compiled gettext translations (from CSV/POT pipeline)
*.translation

# Mono / C# (if you add C# later)
.mono/
mono_crash.*.json

# Local export presets often contain keystore paths or secrets — use an
# `export_presets.cfg.example` in-repo if you need to share structure.
export_presets.cfg
export.cfg

# Typical export output dirs (adjust names if yours differ)
exports/
build/
dist/

# Mobile export scaffolding / build caches
/android/
/ios/
.gradle/

# --- Python (tools/sim_100_days.py, etc.) ---------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python

.venv/
venv/
ENV/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Sim / analysis outputs (regenerated by tools/sim_100_days.py) --------
tools/sim_analysis/*.png

